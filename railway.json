{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm install -g json-server"
  },
  "deploy": {
    "startCommand": "json-server --watch db.json --port $PORT --host 0.0.0.0",
    "restartPolicyType": "ON_FAILURE"
  }
}